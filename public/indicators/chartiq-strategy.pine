//@version=5
strategy("ChartIQ AI Signal Strategy",
  overlay=true,
  initial_capital=10000,
  default_qty_type=
    strategy.percent_of_equity,
  default_qty_value=1,
  commission_type=
    strategy.commission.percent,
  commission_value=0.02,
  slippage=2,
  max_lines_count=500,
  max_labels_count=500,
  max_boxes_count=500)

// ═══════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════

risk_per_trade = input.float(1.0,
  "Risk Per Trade %",
  minval=0.1, maxval=5.0, step=0.1,
  group="Capital Management")
atr_mult_sl = input.float(1.5,
  "ATR Multiplier for SL",
  minval=0.5, maxval=5.0, step=0.1,
  group="Capital Management")
tp1_rr = input.float(2.0,
  "Take Profit 1 R:R",
  minval=0.5, maxval=10.0, step=0.1,
  group="Capital Management")
tp2_rr = input.float(3.0,
  "Take Profit 2 R:R",
  minval=0.5, maxval=10.0, step=0.1,
  group="Capital Management")
use_partial_tp = input.bool(true,
  "Use Partial TP (50% at TP1)",
  group="Capital Management")
use_breakeven = input.bool(true,
  "Move to Breakeven at TP1",
  group="Capital Management")

ema_fast = input.int(20, "Fast EMA",
  group="Trend Filter")
ema_slow = input.int(50, "Slow EMA",
  group="Trend Filter")
ema_trend = input.int(200, "Trend EMA",
  group="Trend Filter")
require_trend = input.bool(true,
  "Require Trend Alignment",
  group="Trend Filter")

min_confluence = input.int(3,
  "Minimum Confluence (1-6)",
  minval=1, maxval=6,
  group="Signal Settings")
use_rsi = input.bool(true,
  "Use RSI Filter",
  group="Signal Settings")
use_volume = input.bool(true,
  "Use Volume Filter",
  group="Signal Settings")
use_session = input.bool(true,
  "Use Session Filter",
  group="Signal Settings")

use_london = input.bool(true,
  "Trade London Session",
  group="Sessions")
use_newyork = input.bool(true,
  "Trade New York Session",
  group="Sessions")
use_asian = input.bool(false,
  "Trade Asian Session",
  group="Sessions")

max_trades_day = input.int(3,
  "Max Trades Per Day",
  minval=1, maxval=10,
  group="Trade Management")

start_date = input.time(
  timestamp("2024-01-01"),
  "Start Date",
  group="Backtest Settings")
end_date = input.time(
  timestamp("2026-12-31"),
  "End Date",
  group="Backtest Settings")

// ═══════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════

ema20 = ta.ema(close, ema_fast)
ema50 = ta.ema(close, ema_slow)
ema200 = ta.ema(close, ema_trend)

bull_trend = ema20 > ema50 and
  ema50 > ema200
bear_trend = ema20 < ema50 and
  ema50 < ema200

trend_ok_bull = require_trend ?
  bull_trend : true
trend_ok_bear = require_trend ?
  bear_trend : true

rsi = ta.rsi(close, 14)
rsi_bull = use_rsi ?
  (rsi > 45 and rsi < 70) : true
rsi_bear = use_rsi ?
  (rsi < 55 and rsi > 30) : true

vol_avg = ta.sma(volume, 20)
vol_confirm = use_volume ?
  volume > vol_avg * 1.1 : true

atr = ta.atr(14)

london_session = not na(time("1440",
  "0800-1700", "Europe/London"))
ny_session = not na(time("1440",
  "0830-1700", "America/New_York"))
asian_session = not na(time("1440",
  "0000-0900", "Asia/Tokyo"))

active_session =
  (use_london and london_session) or
  (use_newyork and ny_session) or
  (use_asian and asian_session)
session_ok = use_session ?
  active_session : true

in_date_range = time >= start_date and
  time <= end_date

// Market Structure
swing_high = ta.pivothigh(high, 5, 5)
swing_low = ta.pivotlow(low, 5, 5)

var float last_sh = na
var float last_sl = na
var float prev_sh = na
var float prev_sl = na

if not na(swing_high)
    prev_sh := last_sh
    last_sh := swing_high

if not na(swing_low)
    prev_sl := last_sl
    last_sl := swing_low

bos_bull = not na(prev_sh) and
  close > prev_sh and
  close[1] <= prev_sh

bos_bear = not na(prev_sl) and
  close < prev_sl and
  close[1] >= prev_sl

// FVG
bull_fvg = low > high[2] and
  close[1] > high[2]
bear_fvg = high < low[2] and
  close[1] < low[2]

var float bull_fvg_top = na
var float bull_fvg_bot = na
var float bear_fvg_top = na
var float bear_fvg_bot = na

if bull_fvg
    bull_fvg_top := low
    bull_fvg_bot := high[2]

if bear_fvg
    bear_fvg_top := low[2]
    bear_fvg_bot := high

in_bull_fvg = not na(bull_fvg_bot) and
  close >= bull_fvg_bot and
  close <= bull_fvg_top

in_bear_fvg = not na(bear_fvg_bot) and
  close >= bear_fvg_bot and
  close <= bear_fvg_top

// Order Blocks
strong_bull_move = close > open and
  (close - open) > atr * 1.5
strong_bear_move = close < open and
  (open - close) > atr * 1.5

var float bull_ob_high = na
var float bull_ob_low = na
var float bear_ob_high = na
var float bear_ob_low = na

if strong_bull_move and close[1] < open[1]
    bull_ob_high := high[1]
    bull_ob_low := low[1]

if strong_bear_move and close[1] > open[1]
    bear_ob_high := high[1]
    bear_ob_low := low[1]

at_bull_ob = not na(bull_ob_low) and
  close >= bull_ob_low and
  close <= bull_ob_high

at_bear_ob = not na(bear_ob_low) and
  close >= bear_ob_low and
  close <= bear_ob_high

// Liquidity Sweeps
liq_sweep_bull =
  low < ta.lowest(low, 20)[1] and
  close > ta.lowest(low, 20)[1] and
  close > open

liq_sweep_bear =
  high > ta.highest(high, 20)[1] and
  close < ta.highest(high, 20)[1] and
  close < open

// Confluence
bull_c1 = trend_ok_bull ? 1 : 0
bull_c2 = rsi_bull ? 1 : 0
bull_c3 = vol_confirm ? 1 : 0
bull_c4 = (in_bull_fvg or at_bull_ob) ?
  1 : 0
bull_c5 = liq_sweep_bull ? 1 : 0
bull_c6 = bos_bull ? 1 : 0
bull_score = bull_c1 + bull_c2 +
  bull_c3 + bull_c4 + bull_c5 + bull_c6

bear_c1 = trend_ok_bear ? 1 : 0
bear_c2 = rsi_bear ? 1 : 0
bear_c3 = vol_confirm ? 1 : 0
bear_c4 = (in_bear_fvg or at_bear_ob) ?
  1 : 0
bear_c5 = liq_sweep_bear ? 1 : 0
bear_c6 = bos_bear ? 1 : 0
bear_score = bear_c1 + bear_c2 +
  bear_c3 + bear_c4 + bear_c5 + bear_c6

// Daily trade counter
var int trades_today = 0
var int last_trade_day = na
current_day = dayofmonth

if na(last_trade_day) or
  current_day != last_trade_day
    trades_today := 0
    last_trade_day := current_day

can_trade = trades_today < max_trades_day and
  strategy.opentrades == 0

// ═══════════════════════════════════════
// ENTRY CONDITIONS
// ═══════════════════════════════════════

buy_condition =
  bull_score >= min_confluence and
  session_ok and
  can_trade and
  in_date_range and
  strategy.position_size == 0

sell_condition =
  bear_score >= min_confluence and
  session_ok and
  can_trade and
  in_date_range and
  strategy.position_size == 0

// ═══════════════════════════════════════
// TRADE EXECUTION
// ═══════════════════════════════════════

var float entry_price_var = na
var float sl_price_var = na
var bool tp1_hit = false

if buy_condition
    buy_sl = not na(last_sl) ?
      math.min(last_sl,
      low - atr * atr_mult_sl) :
      low - atr * atr_mult_sl
    buy_risk = close - buy_sl
    buy_tp1 = close + buy_risk * tp1_rr
    buy_tp2 = close + buy_risk * tp2_rr

    entry_price_var := close
    sl_price_var := buy_sl
    tp1_hit := false
    trades_today += 1

    strategy.entry("Long",
      strategy.long,
      comment="BUY " +
      str.tostring(bull_score) + "/6")

    if use_partial_tp
        strategy.exit("Long TP1", "Long",
          qty_percent=50,
          limit=buy_tp1,
          stop=buy_sl,
          comment="TP1")
        strategy.exit("Long TP2", "Long",
          qty_percent=50,
          limit=buy_tp2,
          stop=buy_sl,
          comment="TP2")
    else
        strategy.exit("Long Exit", "Long",
          limit=buy_tp2,
          stop=buy_sl)

if sell_condition
    sell_sl = not na(last_sh) ?
      math.max(last_sh,
      high + atr * atr_mult_sl) :
      high + atr * atr_mult_sl
    sell_risk = sell_sl - close
    sell_tp1 = close - sell_risk * tp1_rr
    sell_tp2 = close - sell_risk * tp2_rr

    entry_price_var := close
    sl_price_var := sell_sl
    tp1_hit := false
    trades_today += 1

    strategy.entry("Short",
      strategy.short,
      comment="SELL " +
      str.tostring(bear_score) + "/6")

    if use_partial_tp
        strategy.exit("Short TP1", "Short",
          qty_percent=50,
          limit=sell_tp1,
          stop=sell_sl,
          comment="TP1")
        strategy.exit("Short TP2", "Short",
          qty_percent=50,
          limit=sell_tp2,
          stop=sell_sl,
          comment="TP2")
    else
        strategy.exit("Short Exit", "Short",
          limit=sell_tp2,
          stop=sell_sl)

// Breakeven logic
if use_breakeven and
  strategy.position_size > 0 and
  not na(entry_price_var) and
  not tp1_hit
    risk = entry_price_var - sl_price_var
    be_trigger = entry_price_var +
      risk * tp1_rr
    if high >= be_trigger
        tp1_hit := true
        strategy.exit("Long BE", "Long",
          stop=entry_price_var +
          atr * 0.1)

if use_breakeven and
  strategy.position_size < 0 and
  not na(entry_price_var) and
  not tp1_hit
    risk = sl_price_var - entry_price_var
    be_trigger = entry_price_var -
      risk * tp1_rr
    if low <= be_trigger
        tp1_hit := true
        strategy.exit("Short BE", "Short",
          stop=entry_price_var -
          atr * 0.1)

// ═══════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════

plot(ema20, "EMA 20",
  color.new(color.rgb(0,230,118), 60), 1)
plot(ema50, "EMA 50",
  color.new(color.rgb(255,68,68), 60), 1)
plot(ema200, "EMA 200",
  color.white, 2)

plotshape(buy_condition,
  "BUY", shape.labelup,
  location.belowbar,
  color.rgb(0,230,118),
  size=size.normal,
  text="BUY\n" +
  str.tostring(bull_score) + "/6")

plotshape(sell_condition,
  "SELL", shape.labeldown,
  location.abovebar,
  color.rgb(255,68,68),
  size=size.normal,
  text="SELL\n" +
  str.tostring(bear_score) + "/6")

// ═══════════════════════════════════════
// PERFORMANCE DASHBOARD
// ═══════════════════════════════════════

if barstate.islast
    var table perf = table.new(
      position.bottom_right, 2, 8,
      bgcolor=color.new(color.black, 20),
      border_color=color.new(
        color.rgb(0,230,118), 40),
      border_width=1)

    win_rate = strategy.wintrades /
      math.max(
        strategy.closedtrades, 1) * 100
    profit_factor = strategy.grossprofit /
      math.max(
        math.abs(strategy.grossloss), 1)

    table.cell(perf, 0, 0,
      "ChartIQ Strategy",
      text_color=color.rgb(0,230,118),
      text_size=size.small,
      bgcolor=color.new(
        color.rgb(0,230,118), 80))
    table.cell(perf, 1, 0, "Results",
      text_color=color.rgb(0,230,118),
      text_size=size.small,
      bgcolor=color.new(
        color.rgb(0,230,118), 80))

    table.cell(perf, 0, 1,
      "Total Trades",
      text_color=color.white,
      text_size=size.small)
    table.cell(perf, 1, 1,
      str.tostring(
        strategy.closedtrades),
      text_color=color.white,
      text_size=size.small)

    table.cell(perf, 0, 2, "Win Rate",
      text_color=color.white,
      text_size=size.small)
    table.cell(perf, 1, 2,
      str.tostring(
        math.round(win_rate)) + "%",
      text_color=win_rate >= 50 ?
        color.rgb(0,230,118) :
        color.rgb(255,68,68),
      text_size=size.small)

    table.cell(perf, 0, 3, "Net Profit",
      text_color=color.white,
      text_size=size.small)
    table.cell(perf, 1, 3,
      str.tostring(math.round(
        strategy.netprofit)),
      text_color=strategy.netprofit > 0 ?
        color.rgb(0,230,118) :
        color.rgb(255,68,68),
      text_size=size.small)

    table.cell(perf, 0, 4,
      "Profit Factor",
      text_color=color.white,
      text_size=size.small)
    table.cell(perf, 1, 4,
      str.tostring(math.round(
        profit_factor * 100) / 100),
      text_color=profit_factor > 1.5 ?
        color.rgb(0,230,118) :
        color.rgb(255,68,68),
      text_size=size.small)

    table.cell(perf, 0, 5,
      "Max Drawdown",
      text_color=color.white,
      text_size=size.small)
    table.cell(perf, 1, 5,
      str.tostring(math.round(
        strategy.max_drawdown_percent *
        100) / 100) + "%",
      text_color=color.rgb(255,68,68),
      text_size=size.small)

    table.cell(perf, 0, 6, "Avg Win",
      text_color=color.white,
      text_size=size.small)
    table.cell(perf, 1, 6,
      str.tostring(math.round(
        strategy.grossprofit /
        math.max(
          strategy.wintrades, 1))),
      text_color=color.rgb(0,230,118),
      text_size=size.small)

    table.cell(perf, 0, 7, "Avg Loss",
      text_color=color.white,
      text_size=size.small)
    table.cell(perf, 1, 7,
      str.tostring(math.round(
        strategy.grossloss /
        math.max(
          strategy.losstrades, 1))),
      text_color=color.rgb(255,68,68),
      text_size=size.small)

// ═══════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════

alertcondition(buy_condition,
  "ChartIQ Strategy BUY",
  "ChartIQ AI: BUY — " +
  str.tostring(bull_score) +
  "/6 confluence")

alertcondition(sell_condition,
  "ChartIQ Strategy SELL",
  "ChartIQ AI: SELL — " +
  str.tostring(bear_score) +
  "/6 confluence")
